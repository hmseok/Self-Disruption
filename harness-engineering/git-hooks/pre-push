#!/bin/sh
# cowork-pre-push-hook v3 (PR-COORD-4 2026-05-21)
# Repo-tracked pre-push hook — 모든 cowork 세션 공유.
# 설치: git config core.hooksPath harness-engineering/git-hooks
#
# CLAUDE.md 규칙 21 + SESSIONS-COORDINATION § 7 — Cowork 멀티 세션
#   (1) staging 침범 방지 (multi-module commit 차단)
#   (2) v3: push 전 origin 최신 확인 — behind 시 안내 (commit 유실 방지)

# ── v3: origin 최신 확인 (SESSIONS-COORDINATION § 7.1) ──
# push 전 fetch 로 origin/main 비교 — local 이 뒤처졌으면 안내.
# 차단은 안 함 (git 이 어차피 non-fast-forward reject) — 사전 안내 목적.
git fetch origin main --quiet 2>/dev/null || true
_LOCAL=$(git rev-parse HEAD 2>/dev/null)
_REMOTE=$(git rev-parse origin/main 2>/dev/null)
_BASE=$(git merge-base HEAD origin/main 2>/dev/null)
if [ -n "$_REMOTE" ] && [ -n "$_BASE" ] && [ "$_LOCAL" != "$_REMOTE" ] && [ "$_BASE" = "$_LOCAL" ]; then
  echo ""
  echo "⚠ origin/main 이 앞서 있습니다 — 다른 세션이 먼저 push 함."
  echo "  push reject 시 정상 동작 (SESSIONS-COORDINATION § 7.1.a):"
  echo "    git pull --rebase origin main  →  git push  재시도"
  echo ""
fi

# COWORK_ALLOW_MULTI_MODULE=1 면 우회 (의도적 cross-module push)
if [ "$COWORK_ALLOW_MULTI_MODULE" = "1" ]; then
  echo "⚠ COWORK_ALLOW_MULTI_MODULE=1 — multi-module push 허용"
  exit 0
fi

# stdin 으로 push 대상 ref 들 받음
EXIT_CODE=0
while read local_ref local_sha remote_ref remote_sha; do
  # 삭제 push skip
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  # 새 branch push 면 — 너무 많은 commit 검사 회피, 최근 20개만
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    RANGE="$local_sha"
    LIMIT=20
  else
    RANGE="$remote_sha..$local_sha"
    LIMIT=200
  fi

  COMMITS=$(git rev-list --max-count=$LIMIT "$RANGE" 2>/dev/null)
  if [ -z "$COMMITS" ]; then
    continue
  fi

  for commit in $COMMITS; do
    node harness-engineering/scripts/cowork-staging-lint.js --check-commit "$commit" > /dev/null 2>&1
    LINT_R=$?
    if [ $LINT_R -ne 0 ]; then
      echo ""
      echo "❌ pre-push 차단 — commit $commit 가 multi-module 위반"
      echo "   (CLAUDE.md 규칙 21 — Cowork 멀티 세션 staging 침범 방지)"
      echo ""
      node harness-engineering/scripts/cowork-staging-lint.js --check-commit "$commit"
      EXIT_CODE=1
    fi
  done
done

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "  조치 옵션:"
  echo "    1. 잘못된 commit 분리:"
  echo "       git reset --soft HEAD~N"
  echo "       자기 모듈만 git add → commit → push"
  echo ""
  echo "    2. 의도된 cross-module push (드물게):"
  echo "       COWORK_ALLOW_MULTI_MODULE=1 git push origin main"
  exit 1
fi
exit 0
