- SettlementDashboard.tsx 3곳: /api/general_investments?id=, /api/jiip-contracts?id=
  → /api/investments/{id}, /api/jiip/{id} (404 → HTML → 이체 미리보기 JSON 파싱 실패 해소)
- ReportDashboard.tsx 2곳: /api/jiip-contracts, /api/general-investments
  → /api/jiip, /api/investments
- finance/tax/page.tsx: /api/jiip-contracts?ids= → /api/jiip?ids=
- /api/jiip GET에 ?ids= 쿼리 지원 추가 (IN 절)

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 app/api/jiip/route.ts                          | 14 +++++++++++++-
 app/finance/settlement/SettlementDashboard.tsx |  6 +++---
 app/finance/tax/page.tsx                       |  2 +-
 app/report/ReportDashboard.tsx                 |  4 ++--
 4 files changed, 19 insertions(+), 7 deletions(-)

diff --git a/app/api/jiip/route.ts b/app/api/jiip/route.ts
index ba058e1..33b8ba6 100644
--- a/app/api/jiip/route.ts
+++ b/app/api/jiip/route.ts
@@ -18,10 +18,22 @@ export async function GET(request: NextRequest) {
     const carId = searchParams.get('car_id')
     const status = searchParams.get('status')
     const single = searchParams.get('single') === 'true'
+    const idsParam = searchParams.get('ids')
 
     // 단독 회사 ERP — company_id 필터 제거 (해당 컬럼 미존재)
     let data: any[]
-    if (carId && single) {
+    if (idsParam) {
+      const ids = idsParam.split(',').map(s => s.trim()).filter(Boolean)
+      if (ids.length === 0) {
+        data = []
+      } else {
+        const placeholders = ids.map(() => '?').join(',')
+        data = await prisma.$queryRawUnsafe<any[]>(
+          `SELECT * FROM jiip_contracts WHERE id IN (${placeholders}) ORDER BY created_at DESC`,
+          ...ids
+        )
+      }
+    } else if (carId && single) {
       data = await prisma.$queryRaw<any[]>`SELECT * FROM jiip_contracts WHERE car_id = ${carId} LIMIT 1`
     } else if (carId) {
       data = await prisma.$queryRaw<any[]>`SELECT * FROM jiip_contracts WHERE car_id = ${carId} ORDER BY created_at DESC`
