// ============================================================
// Prisma Schema — FMI ERP (Google Cloud SQL MySQL 8.0)
// 생성일: 2026-03-27
//
// 전환 순서:
//   Phase 2: 이 파일 작성 완료
//   Phase 3: 테이블별로 API 라우트를 Supabase SDK → Prisma로 전환
// ============================================================

generator client {
  provider = "prisma-client-js"
  // Cloud SQL Connector 드라이버 사용 (Cloud Run 환경)
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  // 로컬 개발: "mysql://user:pass@127.0.0.1:3307/fmi_erp"
  // Cloud Run: Cloud SQL Connector 사용 (lib/prisma.ts 참조)
}

// ============================================================
// 공통: auth.users 대체 (Firebase UID 기반, Phase 5 이후)
// ============================================================
model Profile {
  id            String    @id @default(uuid()) @db.Char(36)
  email         String    @unique
  name          String?
  role          String    @default("member") // admin, manager, member
  is_active     Boolean   @default(true)
  is_approved   Boolean   @default(false)
  avatar_url    String?
  phone         String?
  department    String?
  position      String?
  password_hash String?   @db.VarChar(255)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt

  @@map("profiles")
}

// ============================================================
// 대차 차량 관리
// ============================================================
model FmiVehicle {
  id               String    @id @default(uuid()) @db.Char(36)
  car_number       String    @unique
  car_type         String?
  car_brand        String?
  car_model        String?
  car_year         Int?
  car_color        String?
  vin              String?
  ownership_type   String    @default("owned") // owned, external_rent, lease
  rental_company   String?
  rental_monthly_cost Decimal? @db.Decimal(12, 0)
  rental_start_date   DateTime? @db.Date
  rental_end_date     DateTime? @db.Date
  rental_contract_no  String?
  purchase_date    DateTime? @db.Date
  purchase_price   Decimal?  @db.Decimal(12, 0)
  depreciation_rate Decimal? @db.Decimal(5, 2)
  investor         String?
  investment_amount Decimal? @db.Decimal(12, 0)
  investment_return_rate Decimal? @db.Decimal(5, 2)
  investment_start_date DateTime? @db.Date
  investment_end_date   DateTime? @db.Date
  insurance_company String?
  insurance_policy_no String?
  insurance_expiry  DateTime? @db.Date
  inspection_expiry DateTime? @db.Date
  status           String    @default("available")
  current_location String?
  mileage          Int       @default(0)
  notes            String?   @db.Text
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt

  rentals FmiRental[]
  payments FmiPayment[]

  @@index([status])
  @@index([ownership_type])
  @@map("fmi_vehicles")
}

// ============================================================
// 사고 접수
// ============================================================
model FmiAccident {
  id                    String    @id @default(uuid()) @db.Char(36)
  cafe24_id             String?   @unique
  receipt_no            String?
  receipt_date          DateTime?
  accident_date         DateTime?
  accident_location     String?
  accident_description  String?   @db.Text
  accident_region_sido  String?
  accident_region_sigungu String?
  customer_name         String?
  customer_phone        String?
  customer_car_number   String?
  customer_car_type     String?
  counterpart_name      String?
  counterpart_phone     String?
  counterpart_car_number String?
  counterpart_insurance String?
  counterpart_claim_no  String?
  insurance_company     String?
  insurance_claim_no    String?
  adjuster_name         String?
  adjuster_phone        String?
  fault_type            String?
  fault_rate            Int?
  repair_needed         Boolean   @default(false)
  repair_shop           String?
  estimated_repair_days Int?
  estimated_repair_cost Decimal?  @db.Decimal(12, 0)
  rental_needed         Boolean   @default(false)
  rental_status         String    @default("none")
  status                String    @default("received")
  handler_id            String?   @db.Char(36)
  handler_name          String?
  source                String    @default("manual")
  raw_data              Json?
  notes                 String?   @db.Text
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt

  rentals FmiRental[]
  timeline FmiRentalTimeline[]

  @@index([status])
  @@index([rental_status])
  @@index([receipt_date])
  @@index([insurance_company])
  @@map("fmi_accidents")
}

// ============================================================
// 대차건 관리 (핵심)
// ============================================================
model FmiRental {
  id                  String    @id @default(uuid()) @db.Char(36)
  accident_id         String?   @db.Char(36)
  rental_no           String?   @unique
  customer_name       String
  customer_phone      String?
  customer_car_number String?
  customer_car_type   String?
  vehicle_id          String?   @db.Char(36)
  vehicle_car_number  String?
  vehicle_car_type    String?
  insurance_company   String?
  insurance_claim_no  String?
  adjuster_name       String?
  adjuster_phone      String?
  dispatch_date       DateTime?
  dispatch_location   String?
  expected_return_date DateTime?
  actual_return_date  DateTime?
  rental_days         Int?
  dispatch_mileage    Int?
  return_mileage      Int?
  driven_km           Int?
  daily_rate          Decimal?  @db.Decimal(10, 0)
  total_rental_fee    Decimal?  @db.Decimal(12, 0)
  additional_charges  Decimal?  @default(0) @db.Decimal(12, 0)
  deduction_amount    Decimal?  @default(0) @db.Decimal(12, 0)
  final_claim_amount  Decimal?  @db.Decimal(12, 0)
  return_condition    String?
  return_fuel_level   String?
  return_damage_yn    Boolean   @default(false)
  return_damage_memo  String?   @db.Text
  return_photos       Json?     // TEXT[] → JSON array
  status              String    @default("pending")
  handler_id          String?   @db.Char(36)
  handler_name        String?
  dispatcher_name     String?
  notes               String?   @db.Text
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  accident  FmiAccident?  @relation(fields: [accident_id], references: [id])
  vehicle   FmiVehicle?   @relation(fields: [vehicle_id], references: [id])
  claims    FmiClaim[]
  settlements FmiSettlement[]
  payments  FmiPayment[]
  timeline  FmiRentalTimeline[]

  @@index([status])
  @@index([accident_id])
  @@index([vehicle_id])
  @@index([insurance_company])
  @@index([dispatch_date])
  @@map("fmi_rentals")
}

// ============================================================
// 보험 청구
// ============================================================
model FmiClaim {
  id                  String    @id @default(uuid()) @db.Char(36)
  rental_id           String    @db.Char(36)
  accident_id         String?   @db.Char(36)
  claim_no            String?   @unique
  insurance_company   String
  insurance_claim_no  String?
  rental_fee          Decimal?  @db.Decimal(12, 0)
  additional_charges  Decimal?  @default(0) @db.Decimal(12, 0)
  total_claim_amount  Decimal?  @db.Decimal(12, 0)
  claim_method        String?
  claim_date          DateTime?
  claim_documents     Json?
  claim_pdf_url       String?
  fax_number          String?
  fax_sent_at         DateTime?
  response_date       DateTime?
  approved_amount     Decimal?  @db.Decimal(12, 0)
  rejected_amount     Decimal?  @db.Decimal(12, 0)
  rejection_reason    String?   @db.Text
  negotiation_memo    String?   @db.Text
  status              String    @default("draft")
  handler_id          String?   @db.Char(36)
  handler_name        String?
  notes               String?   @db.Text
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  rental      FmiRental  @relation(fields: [rental_id], references: [id])
  settlements FmiSettlement[]

  @@index([status])
  @@index([rental_id])
  @@index([insurance_company])
  @@index([claim_date])
  @@map("fmi_claims")
}

// ============================================================
// 정산/입금
// ============================================================
model FmiSettlement {
  id              String    @id @default(uuid()) @db.Char(36)
  claim_id        String?   @db.Char(36)
  rental_id       String?   @db.Char(36)
  settlement_type String?
  amount          Decimal   @db.Decimal(12, 0)
  payment_date    DateTime? @db.Date
  payment_method  String?
  bank_name       String?
  account_no      String?
  depositor       String?
  transaction_no  String?
  matched         Boolean   @default(false)
  match_difference Decimal? @db.Decimal(12, 0)
  notes           String?   @db.Text
  created_at      DateTime  @default(now())

  claim  FmiClaim?  @relation(fields: [claim_id], references: [id])
  rental FmiRental? @relation(fields: [rental_id], references: [id])

  @@index([claim_id])
  @@index([rental_id])
  @@index([payment_date])
  @@map("fmi_settlements")
}

// ============================================================
// 지급 관리
// ============================================================
model FmiPayment {
  id                String    @id @default(uuid()) @db.Char(36)
  payment_category  String
  payee_name        String
  payee_bank        String?
  payee_account     String?
  payee_business_no String?
  vehicle_id        String?   @db.Char(36)
  rental_id         String?   @db.Char(36)
  amount            Decimal   @db.Decimal(12, 0)
  tax_amount        Decimal?  @default(0) @db.Decimal(12, 0)
  total_amount      Decimal?  @db.Decimal(12, 0)
  payment_date      DateTime? @db.Date
  due_date          DateTime? @db.Date
  payment_method    String?
  payment_status    String    @default("pending")
  is_recurring      Boolean   @default(false)
  recurring_period  String?
  recurring_start   DateTime? @db.Date
  recurring_end     DateTime? @db.Date
  notes             String?   @db.Text
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now()) @updatedAt

  vehicle FmiVehicle? @relation(fields: [vehicle_id], references: [id])
  rental  FmiRental?  @relation(fields: [rental_id], references: [id])

  @@index([payment_category])
  @@index([payment_status])
  @@index([payment_date])
  @@map("fmi_payments")
}

// ============================================================
// 대차 타임라인 (이력)
// ============================================================
model FmiRentalTimeline {
  id             String    @id @default(uuid()) @db.Char(36)
  rental_id      String    @db.Char(36)
  accident_id    String?   @db.Char(36)
  event_type     String
  event_title    String
  event_detail   String?   @db.Text
  old_status     String?
  new_status     String?
  created_by     String?   @db.Char(36)
  created_by_name String?
  created_at     DateTime  @default(now())

  rental   FmiRental   @relation(fields: [rental_id], references: [id])
  accident FmiAccident? @relation(fields: [accident_id], references: [id])

  @@index([rental_id])
  @@index([created_at])
  @@map("fmi_rental_timeline")
}

// ============================================================
// 오픈뱅킹
// ============================================================

// ============================================================
// Codef 연동
// ============================================================
model CodefConnection {
  id           String    @id @default(uuid()) @db.Char(36)
  connected_id String
  org_type     String
  org_code     String
  org_name     String
  account_number String?
  is_active    Boolean   @default(true)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now()) @updatedAt

  @@index([connected_id])
  @@index([org_code])
  @@map("codef_connections")
}

model CodefSyncLog {
  id            String    @id @default(uuid()) @db.Char(36)
  sync_type     String
  org_name      String?
  fetched       Int       @default(0)
  inserted      Int       @default(0)
  status        String    @default("success")
  error_message String?   @db.Text
  synced_at     DateTime  @default(now())

  @@index([sync_type])
  @@index([synced_at])
  @@map("codef_sync_logs")
}

// ============================================================
// 공통 코드
// ============================================================
model CodeMaster {
  id         String    @id @default(uuid()) @db.Char(36)
  category   String
  code       String
  value      String
  sort_order Int       @default(0)
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())

  @@index([category, code])
  @@map("code_master")
}

model CommonCode {
  id         String    @id @default(uuid()) @db.Char(36)
  category   String
  code       String
  value      String
  sort_order Int       @default(0)
  is_active  Boolean   @default(true)
  created_at DateTime  @default(now())

  @@unique([category, code])
  @@map("common_codes")
}

// ============================================================
// 거래/재무 관리
// ============================================================
model Transaction {
  id               String    @id @default(uuid()) @db.Char(36)
  company_id       String?   @db.Char(36)
  transaction_date DateTime? @db.Date
  type             String?   // income, expense
  amount           Decimal?  @db.Decimal(15, 0)
  client_name      String?
  description      String?   @db.Text
  payment_method   String?
  status           String?   @default("completed")
  category         String?
  memo             String?   @db.Text
  related_type     String?
  related_id       String?   @db.Char(36)
  ai_matched_type  String?
  ai_matched_id    String?   @db.Char(36)
  final_category   String?
  imported_from    String?
  codef_org_code   String?
  raw_data         Json?
  deleted_at       DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt

  @@index([company_id])
  @@index([transaction_date])
  @@index([status])
  @@index([category])
  @@map("transactions")
}

model ClassificationQueue {
  id                String    @id @default(uuid()) @db.Char(36)
  company_id        String?   @db.Char(36)
  status            String    @default("pending") // pending, confirmed
  source_data       Json?
  ai_category       String?
  ai_matched_type   String?
  ai_matched_id     String?   @db.Char(36)
  final_category    String?
  final_matched_type String?
  final_matched_id  String?   @db.Char(36)
  queue_item_type   String?
  queue_summary     String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @default(now()) @updatedAt

  @@index([company_id])
  @@index([status])
  @@map("classification_queue")
}

model TransactionFlag {
  id                   String    @id @default(uuid()) @db.Char(36)
  company_id           String?   @db.Char(36)
  transaction_id       String?   @db.Char(36)
  queue_id             String?   @db.Char(36)
  flag_type            String?
  flag_reason          String?   @db.Text
  severity             String?
  status               String    @default("pending") // pending, reviewing, approved, personal_confirmed, dismissed
  transaction_date     DateTime? @db.Date
  client_name          String?
  amount               Decimal?  @db.Decimal(15, 0)
  card_id              String?   @db.Char(36)
  employee_id          String?   @db.Char(36)
  employee_name        String?
  reviewer_id          String?   @db.Char(36)
  reviewer_note        String?   @db.Text
  resolved_at          DateTime?
  salary_adjustment_id String?   @db.Char(36)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @default(now()) @updatedAt

  @@index([company_id])
  @@index([status])
  @@map("transaction_flags")
}

model SalaryAdjustment {
  id                    String    @id @default(uuid()) @db.Char(36)
  company_id            String?   @db.Char(36)
  employee_id           String?   @db.Char(36)
  year_month            String?   // YYYY-MM
  adjustment_type       String?   // deduct, add
  amount                Decimal?  @db.Decimal(12, 0)
  reason                String?   @db.Text
  status                String    @default("pending") // pending, approved, applied, cancelled
  source_transaction_id String?   @db.Char(36)
  source_flag_id        String?   @db.Char(36)
  memo                  String?   @db.Text
  approved_by           String?   @db.Char(36)
  approved_at           DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt

  @@index([company_id])
  @@index([employee_id])
  @@index([year_month])
  @@map("salary_adjustments")
}

model ExpenseReceipt {
  id            String    @id @default(uuid()) @db.Char(36)
  user_id       String?   @db.Char(36)
  user_name     String?
  expense_date  DateTime? @db.Date
  card_number   String?
  category      String?
  merchant      String?
  item_name     String?
  customer_team String?
  amount        Decimal?  @db.Decimal(12, 0)
  receipt_url   String?
  memo          String?   @db.Text
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt

  @@index([user_id])
  @@index([expense_date])
  @@map("expense_receipts")
}

// ============================================================
// 계약/견적
// ============================================================
model Contract {
  id              String    @id @default(uuid()) @db.Char(36)
  quote_id        String?   @db.Char(36)
  car_id          String?   @db.Char(36)
  customer_id     String?   @db.Char(36)
  customer_name   String?
  start_date      DateTime? @db.Date
  end_date        DateTime? @db.Date
  term_months     Int?
  deposit         Decimal?  @db.Decimal(12, 0)
  monthly_rent    Decimal?  @db.Decimal(12, 0)
  status          String    @default("pending") // pending, draft, active, ended, completed, expired, cancelled, terminated
  signature_id    String?   @db.Char(36)
  contract_pdf_url String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now()) @updatedAt

  @@index([status])
  @@index([car_id])
  @@index([customer_id])
  @@map("contracts")
}

model Quote {
  id            String    @id @default(uuid()) @db.Char(36)
  status        String    @default("draft") // draft, pending, active, archived
  customer_name String?
  rent_fee      Decimal?  @db.Decimal(12, 0)
  shared_at     DateTime?
  signed_at     DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt

  share_tokens QuoteShareToken[]

  @@index([status])
  @@map("quotes")
}

model QuoteShareToken {
  id         String    @id @default(uuid()) @db.Char(36)
  quote_id   String    @db.Char(36)
  token      String    @unique
  status     String    @default("active") // active, revoked
  expires_at DateTime?
  created_at DateTime  @default(now())

  quote Quote @relation(fields: [quote_id], references: [id])

  @@index([quote_id])
  @@map("quote_share_tokens")
}

model CustomerSignature {
  id             String    @id @default(uuid()) @db.Char(36)
  quote_id       String?   @db.Char(36)
  customer_name  String?
  customer_phone String?
  signed_at      DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now()) @updatedAt

  @@map("customer_signatures")
}

// ============================================================
// 회사/사용자 관리
// ============================================================
model Company {
  id         String    @id @default(uuid()) @db.Char(36)
  name       String
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt

  @@map("companies")
}

model Car {
  id         String    @id @default(uuid()) @db.Char(36)
  brand      String?
  model      String?
  trim       String?
  number     String?
  year       Int?
  image_url  String?
  status     String    @default("active") // active, rented, accident
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt

  @@map("cars")
}

model MemberInvitation {
  id               String    @id @default(uuid()) @db.Char(36)
  email            String
  company_id       String?   @db.Char(36)
  status           String    @default("pending") // pending, accepted, cancelled, expired
  token            String    @unique
  expires_at       DateTime?
  position_id      String?   @db.Char(36)
  department_id    String?   @db.Char(36)
  role             String?
  page_permissions Json?
  accepted_at      DateTime?
  accepted_by      String?   @db.Char(36)
  invited_by       String?   @db.Char(36)
  send_channel     String?   // email, kakao, sms, both
  recipient_phone  String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt

  @@index([token])
  @@index([email])
  @@map("member_invitations")
}

model AdminInviteCode {
  id          String    @id @default(uuid()) @db.Char(36)
  code        String    @unique
  description String?
  created_by  String?   @db.Char(36)
  expires_at  DateTime?
  used_at     DateTime?
  used_by     String?   @db.Char(36)
  created_at  DateTime  @default(now())

  @@map("admin_invite_codes")
}

// ============================================================
// 급여/인사
// ============================================================
model Payslip {
  id                        String    @id @default(uuid()) @db.Char(36)
  company_id                String?   @db.Char(36)
  employee_id               String?   @db.Char(36)
  pay_period                String?   // YYYY-MM
  base_salary               Decimal?  @db.Decimal(12, 0)
  total_allowances          Decimal?  @db.Decimal(12, 0)
  allowance_details         Json?
  gross_salary              Decimal?  @db.Decimal(12, 0)
  national_pension          Decimal?  @db.Decimal(12, 0)
  health_insurance          Decimal?  @db.Decimal(12, 0)
  long_care_insurance       Decimal?  @db.Decimal(12, 0)
  employment_insurance      Decimal?  @db.Decimal(12, 0)
  income_tax                Decimal?  @db.Decimal(12, 0)
  local_income_tax          Decimal?  @db.Decimal(12, 0)
  tax_type                  String?
  total_deductions          Decimal?  @db.Decimal(12, 0)
  expense_claims            Json?
  expense_deductions        Json?
  net_salary                Decimal?  @db.Decimal(12, 0)
  status                    String    @default("draft") // draft, confirmed, paid
  paid_date                 DateTime? @db.Date
  memo                      String?   @db.Text
  meal_expense_total        Decimal?  @db.Decimal(12, 0)
  meal_expense_allowance    Decimal?  @db.Decimal(12, 0)
  meal_expense_excess       Decimal?  @db.Decimal(12, 0)
  card_spending_total       Decimal?  @db.Decimal(12, 0)
  overtime_hours            Decimal?  @db.Decimal(5, 2)
  overtime_pay              Decimal?  @db.Decimal(12, 0)
  custom_deductions_applied Json?
  employment_type_snapshot  String?
  salary_type_snapshot      String?
  created_at                DateTime  @default(now())
  updated_at                DateTime  @default(now()) @updatedAt

  @@index([company_id])
  @@index([employee_id])
  @@index([pay_period])
  @@map("payslips")
}

model EmployeeSalary {
  id                   String    @id @default(uuid()) @db.Char(36)
  company_id           String?   @db.Char(36)
  employee_id          String?   @db.Char(36)
  base_salary          Decimal?  @db.Decimal(12, 0)
  allowances           Json?
  deduction_overrides  Json?
  payment_day          Int?
  tax_type             String?
  bank_name            String?
  account_number       String?
  account_holder       String?
  is_active            Boolean   @default(true)
  employment_type      String?
  salary_type          String?
  annual_salary        Decimal?  @db.Decimal(15, 0)
  hourly_rate          Decimal?  @db.Decimal(10, 2)
  daily_rate           Decimal?  @db.Decimal(10, 2)
  working_hours_per_week Int?
  dependents_count     Int?
  net_salary_mode      String?
  target_net_salary    Decimal?  @db.Decimal(12, 0)
  custom_deductions    Json?
  expanded_allowances  Json?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @default(now()) @updatedAt

  @@unique([company_id, employee_id])
  @@index([company_id])
  @@map("employee_salaries")
}

model Freelancer {
  id         String    @id @default(uuid()) @db.Char(36)
  name       String
  status     String    @default("active") // active, inactive
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt

  @@map("freelancers")
}

model MealExpenseMonthly {
  id                   String    @id @default(uuid()) @db.Char(36)
  employee_id          String?   @db.Char(36)
  year_month           String?   // YYYY-MM
  total_meal_spending  Decimal?  @db.Decimal(12, 0)
  base_allowance       Decimal?  @db.Decimal(12, 0)
  excess_amount        Decimal?  @db.Decimal(12, 0)
  transaction_count    Int?
  status               String    @default("pending") // pending, approved, applied
  created_at           DateTime  @default(now())
  updated_at           DateTime  @default(now()) @updatedAt

  @@index([employee_id])
  @@map("meal_expense_monthly")
}

model CorporateCard {
  id                  String    @id @default(uuid()) @db.Char(36)
  card_number         String?
  assigned_to         String?   @db.Char(36)
  holder_name         String?
  card_alias          String?
  assigned_employee_id String?  @db.Char(36)
  status              String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  @@map("corporate_cards")
}

// ============================================================
// 정산 공유
// ============================================================
model SettlementShare {
  id                  String    @id @default(uuid()) @db.Char(36)
  token               String    @unique
  recipient_name      String?
  recipient_phone     String?
  settlement_month    String?   // YYYY-MM
  payment_date        DateTime? @db.Date
  total_amount        Decimal?  @db.Decimal(12, 0)
  items               Json?
  breakdown           Json?
  transaction_details Json?
  bank_info           Json?
  message             String?   @db.Text
  status              String    @default("active")
  view_count          Int       @default(0)
  expires_at          DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  @@index([token])
  @@map("settlement_shares")
}

// ============================================================
// 오픈뱅킹 (실제 마이그레이션된 컬럼 기준)
// ============================================================
model OpenBankingAccount {
  id                   String    @id @default(uuid()) @db.Char(36)
  user_seq_no          String?
  fin_use_num          String?   @unique
  bank_code            String?
  bank_name            String?
  account_num_masked   String?
  account_holder_name  String?
  access_token         String?   @db.Text
  refresh_token        String?   @db.Text
  token_expires_at     DateTime?
  is_active            Boolean   @default(true)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @default(now()) @updatedAt

  open_transactions OpenBankingTransaction[]

  @@map("openbanking_accounts")
}

model OpenBankingTransaction {
  id                   String    @id @default(uuid()) @db.Char(36)
  account_id           String?   @db.Char(36)
  fin_use_num          String?
  bank_code            String?
  bank_name            String?
  account_num_masked   String?
  tran_date            String?
  tran_time            String?
  tran_type            String?
  tran_type_name       String?
  tran_amt             Decimal?  @db.Decimal(15, 0)
  after_balance_amt    Decimal?  @db.Decimal(15, 0)
  print_content        String?
  branch_name          String?
  unique_tran_no       String?   @unique
  created_at           DateTime  @default(now())

  account OpenBankingAccount? @relation(fields: [account_id], references: [id])

  @@index([account_id])
  @@index([tran_date])
  @@map("openbanking_transactions")
}

// ============================================================
// 카드 관리 (Phase 3 추가)
// ============================================================
model CardAssignmentHistory {
  id                  String    @id @default(uuid()) @db.Char(36)
  card_id             String?   @db.Char(36)
  employee_id         String?   @db.Char(36)
  assigned_from       DateTime? @db.Date
  assigned_to         DateTime? @db.Date
  reason              String?
  assigned_by         String?   @db.Char(36)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  @@index([card_id])
  @@index([employee_id])
  @@map("card_assignment_history")
}

model CardLimitSettings {
  id                  String    @id @default(uuid()) @db.Char(36)
  type                String?   // card_company, dept, employee
  key                 String?   // 카드사명, 부서명, 직원ID
  monthly_limit       Decimal?  @db.Decimal(12, 0)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  @@unique([type, key])
  @@map("card_limit_settings")
}

// ============================================================
// 프리랜서 및 세무 (Phase 3 추가)
// ============================================================
model FreelancerPayment {
  id                  String    @id @default(uuid()) @db.Char(36)
  freelancer_id       String?   @db.Char(36)
  amount              Decimal?  @db.Decimal(12, 0)
  payment_date        DateTime? @db.Date
  invoice_no          String?
  description         String?   @db.Text
  status              String?   @default("pending") // pending, completed, cancelled
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  @@index([freelancer_id])
  @@index([payment_date])
  @@map("freelancer_payments")
}

model CustomerTaxInvoice {
  id                  String    @id @default(uuid()) @db.Char(36)
  customer_id         String?   @db.Char(36)
  invoice_no          String?   @unique
  invoice_date        DateTime? @db.Date
  amount              Decimal?  @db.Decimal(12, 0)
  tax_amount          Decimal?  @db.Decimal(12, 0)
  description         String?   @db.Text
  status              String?   @default("issued")
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  @@index([customer_id])
  @@index([invoice_date])
  @@map("customer_tax_invoices")
}

model TaxFilingRecord {
  id                  String    @id @default(uuid()) @db.Char(36)
  year                Int?
  filing_date         DateTime? @db.Date
  filing_type         String?   // individual, corporate
  status              String?   @default("draft")
  total_income        Decimal?  @db.Decimal(12, 0)
  total_deduction     Decimal?  @db.Decimal(12, 0)
  tax_amount          Decimal?  @db.Decimal(12, 0)
  memo                String?   @db.Text
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  @@index([year])
  @@index([filing_date])
  @@map("tax_filing_records")
}

// ============================================================
// 투자 관리 (Phase 3 추가)
// ============================================================
model InvestmentDeposit {
  id                  String    @id @default(uuid()) @db.Char(36)
  investment_id       String?   @db.Char(36)
  deposit_date        DateTime? @db.Date
  amount              Decimal?  @db.Decimal(12, 0)
  description         String?   @db.Text
  status              String?   @default("pending")
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  @@index([investment_id])
  @@index([deposit_date])
  @@map("investment_deposits")
}

// ============================================================
// 메시징 / 라이프사이클 (Supabase 탈출 후 추가)
// ============================================================
model MessageTemplate {
  id                  String    @id @default(uuid()) @db.Char(36)
  company_id          String?   @db.Char(36)
  template_key        String
  channel             String    // sms, kakao, email, push
  subject             String?
  body                String    @db.Text
  html_template       String?   @db.LongText
  kakao_template_code String?
  kakao_button_json   Json?
  is_active           Boolean   @default(true)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt

  @@index([template_key, channel])
  @@index([company_id])
  @@map("message_templates")
}

model MessageSendLog {
  id               String    @id @default(uuid()) @db.Char(36)
  company_id       String?   @db.Char(36)
  template_key     String?
  channel          String    // sms, kakao, email, push
  recipient        String
  recipient_name   String?
  subject          String?
  body             String    @db.Text
  status           String    @default("pending") // pending, sent, failed, delivered
  result_code      String?
  result_message   String?
  error_detail     String?   @db.Text
  related_type     String?
  related_id       String?   @db.Char(36)
  sent_by          String?   @db.Char(36)
  sent_at          DateTime?
  created_at       DateTime  @default(now())

  @@index([company_id])
  @@index([related_type, related_id])
  @@index([sent_at])
  @@map("message_send_logs")
}

model QuoteLifecycleEvent {
  id          String    @id @default(uuid()) @db.Char(36)
  quote_id    String    @db.Char(36)
  contract_id String?   @db.Char(36)
  event_type  String    // created, shared, sent, viewed, signed, contract_created, revoked, pdf_stored
  channel     String?   // sms, kakao, email, link
  recipient   String?
  metadata    Json?
  actor_id    String?   @db.Char(36)
  created_at  DateTime  @default(now())

  @@index([quote_id])
  @@index([event_type])
  @@index([created_at])
  @@map("quote_lifecycle_events")
}

// ============================================================
// 페이지 권한 (RBAC)
// ============================================================
model UserPagePermission {
  id          String    @id @default(uuid()) @db.Char(36)
  user_id     String    @db.Char(36)
  page_path   String    @db.VarChar(255)
  can_view    Boolean   @default(false)
  can_create  Boolean   @default(false)
  can_edit    Boolean   @default(false)
  can_delete  Boolean   @default(false)
  data_scope  String    @default("all") // all, department, own
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt

  @@unique([user_id, page_path])
  @@index([user_id])
  @@map("user_page_permissions")
}
