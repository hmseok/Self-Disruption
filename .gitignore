# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# mobile embedded repos (Xcode/React Native 자동생성)
mobile/SelfDisruption/
mobile/SelfDisruptionApp/

# SQL migrations (Supabase SQL Editor에서 수동 실행)
/sql/

# 구형 파일 아카이브
/_archive/

# Google/Firebase 서비스 키 (절대 커밋 금지)
GoogleService-Info*.plist
google-services.json

# 마이그레이션 스크립트 (DB 비밀번호 포함 — 절대 커밋 금지)
scripts/migrate/01_pgloader.load
